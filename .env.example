# ============================================================
# PROTEX — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to version control.
# ============================================================

# ── AI Provider ─────────────────────────────────────────────
# Hermes-4-70B via OpenRouter (recommended for hackathon)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_HERMES_MODEL=nousresearch/hermes-4-70b

# Fallback: direct API endpoint (if self-hosted)
VITE_HERMES_BASE_URL=https://openrouter.ai/api/v1

# ── App Config ───────────────────────────────────────────────
VITE_APP_NAME=Protex
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ── Feature Flags ────────────────────────────────────────────
VITE_ENABLE_SCAN_HISTORY=true
VITE_ENABLE_EXPORT_REPORT=true
VITE_ENABLE_BULK_SCAN=false
VITE_ENABLE_ANALYTICS=false

# ── Rate Limiting ────────────────────────────────────────────
VITE_MAX_REQUESTS_PER_MINUTE=20
VITE_MAX_SCAN_CHARS=5000

# ── Sentry (optional, production only) ───────────────────────
# VITE_SENTRY_DSN=your_sentry_dsn_here
